                <mxCell id="18" value="&lt;p style=&quot;margin-top: 0px;&quot;&gt;&lt;span style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;o valor &lt;/span&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;b&gt;dificuldade &lt;/b&gt;&lt;/span&gt;&lt;span style=&quot;font-size: 12px; font-weight: 400;&quot;&gt;deve ser entre 1-5, 1: 5, 2: 10, 3: 15, 4: 20, 5: 25&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin-top: 0px;&quot;&gt;https://chatgpt.com/share/6a04dbfc-7cc0-83e9-8b92-2e57ebccebed&lt;/p&gt;&lt;p style=&quot;margin-top: 0px;&quot;&gt;&lt;br&gt;&lt;span style=&quot;color: rgb(63, 63, 63); font-size: 12px; font-weight: 400; background-color: transparent;&quot;&gt;pontosNatureza() = dificuldade * 5&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: rgb(63, 63, 63); font-size: 12px; font-weight: normal;&quot;&gt;pontosCarbono() = 16 pontos por quilo, mathRound(kgCarbono * 16)&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;pontosAgua() = mathRound(qtdeLitros * 1 )&lt;/span&gt;&lt;span style=&quot;color: rgb(63, 63, 63);&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color: rgb(63, 63, 63);&quot;&gt;pontosReciclagem() = 160 pontos por quilos reciclados, mathRound(qtdeReciclada * 1.6)&lt;/span&gt;&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;align=left;" parent="1" vertex="1">
